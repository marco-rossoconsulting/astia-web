---
import BaseLayout from '@layouts/BaseLayout.astro';
import JournalContent from '@components/page-content/JournalContent.astro';
import { getEntry } from 'astro:content';

const lang = 'it' as 'en' | 'de' | 'it';
const page = await getEntry('pages', 'journal-index');
const seo = page.data.seo;
---
<BaseLayout lang={lang} page="journal" seo={seo} currentPath="/it/journal">
  <JournalContent lang={lang} />
</BaseLayout>
