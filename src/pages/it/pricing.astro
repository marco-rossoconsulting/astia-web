---
import BaseLayout from '@layouts/BaseLayout.astro';
import PricingContent from '@components/page-content/PricingContent.astro';
import { getEntry } from 'astro:content';

const lang = 'it' as 'en' | 'de' | 'it';
const page = await getEntry('pages', 'pricing');
const seo = page.data.seo;
---
<BaseLayout lang={lang} page="pricing" seo={seo} currentPath="/it/pricing">
  <PricingContent lang={lang} />
</BaseLayout>
