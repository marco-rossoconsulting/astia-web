---
import BaseLayout from '@layouts/BaseLayout.astro';
import ApplyContent from '@components/page-content/ApplyContent.astro';
import { getEntry } from 'astro:content';

const lang = 'it' as 'en' | 'de' | 'it';
const page = await getEntry('pages', 'apply');
const seo = page.data.seo;
---
<BaseLayout lang={lang} page="apply" seo={seo} currentPath="/it/apply">
  <ApplyContent lang={lang} />
</BaseLayout>
