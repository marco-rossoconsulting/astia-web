---
import BaseLayout from '@layouts/BaseLayout.astro';
import HowContent from '@components/page-content/HowContent.astro';
import { getEntry } from 'astro:content';

const lang = 'en' as 'en' | 'de' | 'it';
const page = await getEntry('pages', 'how');
const seo = page.data.seo;
---
<BaseLayout lang={lang} page="how" seo={seo} currentPath="/how-it-works">
  <HowContent lang={lang} />
</BaseLayout>
