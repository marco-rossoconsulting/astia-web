---
import '@/styles/global.css';
import Nav from '@components/Nav.astro';
import Footer from '@components/Footer.astro';
import { getEntry } from 'astro:content';

interface Props {
  lang: 'en' | 'de' | 'it';
  page: 'home' | 'how' | 'pricing' | 'apply' | 'journal' | 'article';
  seo: {
    title: { en: string; de: string; it: string };
    description: { en: string; de: string; it: string };
    ogImage?: string;
    ogImageAlt?: { en: string; de: string; it: string };
  };
  currentPath: string;
}

const { lang, page, seo, currentPath } = Astro.props;
const site = await getEntry('site', 'general');
const siteData = site.data as any;

const title = seo.title[lang];
const description = seo.description[lang];
const ogImage = seo.ogImage || '/images/og-default.jpg';
const ogImageAlt = seo.ogImageAlt?.[lang] || title;

const siteUrl = 'https://astiaweb.com';
const canonical = `${siteUrl}${currentPath}`;

// Build hreflang alternates
const stripLangPrefix = (path: string) =>
  path.replace(/^\/(de|it)\//, '/').replace(/^\/(de|it)$/, '/');
const basePath = stripLangPrefix(currentPath);
const altUrls = {
  en: `${siteUrl}${basePath === '/' ? '/' : basePath}`,
  de: `${siteUrl}/de${basePath === '/' ? '' : basePath}`,
  it: `${siteUrl}/it${basePath === '/' ? '' : basePath}`,
};

const orgJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: siteData.brand.name,
  url: siteUrl,
  logo: `${siteUrl}/images/logo.png`,
  description: siteData.schema.organizationDescription[lang],
  email: siteData.brand.email,
  telephone: siteData.brand.phone,
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Via Don Gagliardi 23',
    postalCode: '6932',
    addressLocality: 'Lugano',
    addressCountry: 'CH',
  },
  parentOrganization: {
    '@type': 'Organization',
    name: siteData.brand.parentCompany,
  },
  sameAs: [siteData.social.linkedin].filter(Boolean),
};
---
<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    {/* Google tag (gtag.js) */}
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-EREW8N0F4N"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-EREW8N0F4N');
    </script>

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    {/* hreflang alternates */}
    <link rel="alternate" hreflang="en" href={altUrls.en} />
    <link rel="alternate" hreflang="de" href={altUrls.de} />
    <link rel="alternate" hreflang="it" href={altUrls.it} />
    <link rel="alternate" hreflang="x-default" href={altUrls.en} />

    {/* Open Graph */}
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}${ogImage}`} />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:locale" content={lang === 'en' ? 'en_US' : lang === 'de' ? 'de_DE' : 'it_IT'} />
    <meta property="og:site_name" content={siteData.brand.name} />

    {/* Twitter */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />

    {/* Fonts */}
    <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://api.fontshare.com/v2/css?f[]=editorial-new@400,400i&f[]=general-sans@400,500,600&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {/* JSON-LD */}
    <script type="application/ld+json" set:html={JSON.stringify(orgJsonLd)} />
  </head>
  <body>
    <Nav lang={lang} page={page} currentPath={currentPath} />
    <main>
      <slot />
    </main>
    <Footer lang={lang} />

    {/* GA4 event tracking */}
    <script is:inline>
      document.addEventListener('DOMContentLoaded', function () {
        /* Track apply form submission */
        var form = document.querySelector('form[name="apply"]');
        if (form) {
          form.addEventListener('submit', function () {
            if (typeof gtag === 'function') {
              gtag('event', 'form_submit', { form_name: 'apply' });
            }
          });
        }

        /* Track outbound link clicks */
        document.querySelectorAll('a[href^="http"], a[href^="mailto"], a[href^="tel"]').forEach(function (link) {
          link.addEventListener('click', function () {
            if (typeof gtag === 'function') {
              gtag('event', 'outbound_link', {
                link_url: link.href,
                link_text: link.textContent.trim()
              });
            }
          });
        });
      });
    </script>
  </body>
</html>
