---
interface Props {
  headers: string[];
  rows: Array<{ label: string; agency: string; builder: string; astia: string }>;
}
const { headers, rows } = Astro.props;
---
<table class="cmp-table">
  <thead>
    <tr>
      {headers.map((h, i) => (
        <th class={i === 3 ? 'cmp-us-head' : ''}>{h}</th>
      ))}
    </tr>
  </thead>
  <tbody>
    {rows.map(row => (
      <tr>
        <td>{row.label}</td>
        <td class="text-stone">{row.agency}</td>
        <td class="text-stone">{row.builder}</td>
        <td class="cmp-us">{row.astia}</td>
      </tr>
    ))}
  </tbody>
</table>
