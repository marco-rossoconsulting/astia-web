---
interface Props {
  labels: string[];
}
const { labels } = Astro.props;
---
<svg class="lifecycle-diagram" viewBox="0 0 800 320" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <marker id="arrowhead" markerWidth="10" markerHeight="7" refX="9" refY="3.5" orient="auto">
      <polygon points="0 0, 10 3.5, 0 7" fill="#6B6B66" />
    </marker>
  </defs>

  {/* Nodes positioned on a horizontal axis */}
  {[0, 1, 2, 3].map((i) => {
    const x = 100 + i * 200;
    const y = 160;
    return (
      <g>
        <circle cx={x} cy={y} r="48" fill="#FAFAF7" stroke="#C41E3A" stroke-width="1.5" />
        <text x={x} y={y - 4} text-anchor="middle" font-family="'JetBrains Mono', monospace" font-size="11" fill="#C41E3A" letter-spacing="0.12em">{`0${i + 1}`}</text>
        <text x={x} y={y + 16} text-anchor="middle" font-family="'Editorial New', serif" font-size="16" fill="#141414">{labels[i]}</text>
      </g>
    );
  })}

  {/* Arrows */}
  {[0, 1, 2].map((i) => {
    const x1 = 100 + i * 200 + 50;
    const x2 = 100 + (i + 1) * 200 - 50;
    return (
      <line x1={x1} y1="160" x2={x2 - 6} y2="160" stroke="#6B6B66" stroke-width="1" marker-end="url(#arrowhead)" />
    );
  })}

  {/* Loop-back arrow (dashed, going below) */}
  <path d="M 698 200 Q 698 280 400 280 Q 100 280 100 200" fill="none" stroke="#C41E3A" stroke-width="1" stroke-dasharray="4 4" marker-end="url(#arrowhead)" opacity="0.6" />
</svg>
